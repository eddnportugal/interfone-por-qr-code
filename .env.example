# ═══════════════════════════════════════════
# Portaria X — Environment Variables
# ═══════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# JWT Secret (change in production!)
JWT_SECRET=dev-secret-change-in-production-32chars!!

# ═══════════════════════════════════════════
# Amazon SES — Email Service
# ═══════════════════════════════════════════
# Create an IAM user in AWS Console with AmazonSESFullAccess policy
# https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_SES_REGION=sa-east-1

# Sender email (must be from verified domain in SES)
SES_FROM_EMAIL=naoresponda@portariax.com.br
SES_FROM_NAME=Portaria X

# App URL (for email action buttons)
APP_URL=https://portariax.com.br
