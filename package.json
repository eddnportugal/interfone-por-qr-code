{
  "name": "app-interfone",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "start": "node dist-server/index.js",
    "build:server": "tsc -p tsconfig.server.json || true",
    "build:all": "npm run build && npm run build:server",
    "build:android": "vite build --mode capacitor && npx cap copy android && npx cap sync android",
    "cap:open": "npx cap open android",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.999.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/push-notifications": "^8.0.1",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "@vladmandic/face-api": "^1.7.15",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "canvas": "^3.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ewelink-api-next": "^1.0.4",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "face-api.js": "^0.22.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^7.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
